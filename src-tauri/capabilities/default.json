{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default capabilities for the Karaoke Successor app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:webview:default",
    "core:event:default",
    "core:event:allow-listen",
    "core:event:allow-emit",
    "core:event:allow-emit-to",
    "shell:default",
    "shell:allow-open",
    {
      "identifier": "fs:allow-read-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$MUSIC/**" },
        { "path": "$PICTURES/**" },
        { "path": "$VIDEO/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-read-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$MUSIC/**" },
        { "path": "$PICTURES/**" },
        { "path": "$VIDEO/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-write-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-write-text-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-read-dir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$MUSIC/**" },
        { "path": "$PICTURES/**" },
        { "path": "$VIDEO/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-exists",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$MUSIC/**" },
        { "path": "$PICTURES/**" },
        { "path": "$VIDEO/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-mkdir",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-remove",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-rename",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-copy-file",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    {
      "identifier": "fs:allow-watch",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$CWD/**" },
        { "path": "**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm"
  ]
}
