{
  "$schema": "https://schema.tauri.app/capability/2",
  "identifier": "default",
  "description": "Default capabilities for the Karaoke Successor app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-start-dragging",
    "core:window:allow-minimize",
    "core:window:allow-toggle-maximize",
    "core:window:allow-close",
    "core:window:allow-set-size",
    "core:window:allow-set-position",
    "core:window:allow-set-focus",
    "core:webview:default",
    "shell:default",
    "shell:allow-open",
    "fs:default",
    "fs:allow-read-text-file",
    "fs:allow-write-text-file",
    "fs:allow-read-dir",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-rename",
    "fs:allow-copy-file",
    "fs:allow-watch",
    {
      "identifier": "fs:scope",
      "allow": [
        { "path": "$HOME/**" },
        { "path": "$RESOURCE/**" },
        { "path": "$APPDATA/**" },
        { "path": "$APPLOCALDATA/**" },
        { "path": "$APPCONFIG/**" },
        { "path": "$DESKTOP/**" },
        { "path": "$DOCUMENTS/**" },
        { "path": "$DOWNLOAD/**" },
        { "path": "$MUSIC/**" },
        { "path": "$PICTURES/**" },
        { "path": "$VIDEO/**" }
      ]
    },
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-ask",
    "dialog:allow-confirm"
  ]
}
